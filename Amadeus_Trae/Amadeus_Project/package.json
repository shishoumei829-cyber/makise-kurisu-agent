{
  "name": "amadeus-project",
  "version": "1.0.0",
  "description": "Amadeus Project - Kurisu Makise AI Companion",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "ingest": "node ingest.js"
  },
  "build": {
    "appId": "com.amadeus.kurisu",
    "productName": "Amadeus",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Amadeus"
    }
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.41",
    "@langchain/ollama": "^1.2.6",
    "@langchain/textsplitters": "^1.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "hnswlib-node": "^3.0.0",
    "langchain": "^1.3.4",
    "systeminformation": "^5.31.3"
  }
}
